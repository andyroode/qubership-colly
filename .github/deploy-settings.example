# GitHub repository settings for Deploy Colly workflow
# Settings → Secrets and variables → Actions
#
# ── Deploy Colly workflow inputs ─────────────────────────────────────────────
# chart-source: helm-repo (default) | release | artifact
#   helm-repo — helm repo on gh-pages (recommended)
#   release   — GitHub pre-release dev-0.0.0-<docker-tag>
#   artifact  — workflow artifacts from a Build run (shorter retention)
# artifact-type (when chart-source=release or artifact):
#   chart-package  — packaged .tgz (recommended)
#   charts-archive — helm-charts-<version>.tar.gz source tree
# chart-version: latest or 0.0.0-<docker-tag> (e.g. 0.0.0-feature-checking-build, 0.0.0-latest on main)
#
# Dev Helm repo (fork, publish-helm-chart on):
#   https://<owner>.github.io/<repo>/  — index on gh-pages
#   GitHub Releases: dev-0.0.0-<docker-tag>
#
# ── Secrets (substituted at deploy time only) ────────────────────────────────
# Names must match ${...} placeholders in charts/qubership-colly/values.yaml
# These values are NOT baked into the Helm chart published to GHCR.
#
# PROJECT_GIT_REPO_URL_EXAMPLE     Git URL of project configuration repo
# GH_TOKEN_EXAMPLE                 Git token for project configuration repo
# K8S_KEYCLOAK_EXAMPLE             Keycloak OIDC URL (all services idp.url)
# REDIS_HOST_EXAMPLE               Redis connection URL
# REDIS_HOST_ADMIN                 Redis username
# REDIS_HOST_PASSWORD              Redis password
#
# ── Already used by deploy workflow ──────────────────────────────────────────
# AWS_ACCESS_KEY_ID                (secret)
# AWS_SECRET_ACCESS_KEY            (secret)
# AWS_REGION                       (variable, default us-east-1 in workflow)
# TF_VAR_EKS_NEW_CLUSTERNAME       (variable, optional override)
# TF_VAR_COLLY_INSTALL_NAMESPACE   (variable, optional override)
# COLLY_HELM_RELEASE               (variable, optional; default = install namespace, e.g. qubership-colly-test)
# COLLY_HELM_EXTRA_ARGS            (variable, optional extra helm args)
# COLLY_CLOUD_PUBLIC_HOST          (variable, optional public ingress host)
